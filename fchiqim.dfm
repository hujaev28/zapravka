  object haridor: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      
        'SELECT distinct h.id,h.nom FROM s_haridor h , asos a, asos_slave' +
        ' s,s_tovar t where t.id=s.tovar_id and s.asos_id=a.id and h.id=a' +
        '.h_id  and a.sana="2021-08-31"')
