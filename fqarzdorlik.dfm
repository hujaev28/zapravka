  object main: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      
        'SELECT s.id,main.serial,s.slave_id,s.kirim_id,s.main_id FROM sla' +
        've_main s,main where del_flag=1 and main.id=s.main_id and s.slav' +
        'e_id=:id order by id')
    Params = <
      item
        DataType = ftInteger
        Name = 'id'
        ParamType = ptUnknown
      end>
    DataSource = DMS.Dk_slave
    Left = 905
    Top = 488
    ParamData = <
      item
        DataType = ftInteger
        Name = 'id'
        ParamType = ptUnknown
      end>
  end
