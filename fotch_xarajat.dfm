  object itog: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      
        'SELECT reg_lis,s_faol.izoh as faol,lbd_marka.nomi as marka,nomer' +
        ',lbd_lk.mesta,'
      
        'n_prot,d_prot,lbd_lis.lis,d_lis_b,d_lis_e,lis_k,d_lk_b,d_lk_e,po' +
        'shlina,lbd_lk.dollar'
      'FROM lbd_lis,lbd_lk,s_faol,lbd_marka'
      
        'WHERE lbd_lk.sf=:id and lbd_lk.faol_lk=s_faol.subid and lbd_lk.l' +
        'is_id=lbd_lis.id and lbd_lk.marka=lbd_marka.subid'
      ''
      ' '
      '')
    Params = <
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    Left = 600
    Top = 360
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
  end
