  object qoldi: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      'SELECT a.id,a.sana,s.kol_ost,s.kol_in_ost,s.sotish,s.sotish_d '
      
        'FROM asos_slave s, asos a where s.del_flag=1 and a.id=s.asos_id ' +
        'and s.tovar_id=:tovar_id and a.tur_oper in (1,4,5) and (s.kol_os' +
        't > 0 or s.kol_in_ost>0) order by a.sana asc')
    Params = <
      item
        DataType = ftUnknown
        Name = 'tovar_id'
        ParamType = ptUnknown
      end>
    DataSource = DMS.Ds_t_all
    Left = 742
    Top = 524
