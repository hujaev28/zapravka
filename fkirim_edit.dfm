  object serttovar: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      
        'SELECT serttovar.id,serttovar.seriya,serttovar.srok,sert.nomer,s' +
        'ert.filenom FROM serttovar,sert where serttovar.del_flag=1 and s' +
        'ert.id=serttovar.sert_id and sert.id=serttovar.sert_id and sertt' +
        'ovar.tovar_id=:id')
