  object ztovar: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      
        'SELECT t.nom,SUM(s.kol*t.kol_in+s.kol_in)/t.kol_in as jami_kol,s' +
        '.sotish,SUM(s.kol)  as kol,sum(s.summa_all) as jami FROM asos a,' +
        ' asos_slave s, s_tovar t WHERE a.id=s.asos_id and s.tovar_id=t.i' +
        'd and a.tur_oper in (2) and s.del_flag=1 and a.zet_id=:id  group' +
        ' by t.nom order by t.nom')
    Params = <
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    DataSource = DMS.Dzet
    Left = 841
    Top = 304
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
  end
