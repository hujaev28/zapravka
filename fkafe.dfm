  object zofis: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      
        'SELECT u.login as nom,COUNT(a.id) AS kol,SUM(a.xizmat) AS jami F' +
        'ROM asos a,user u WHERE u.id = a.user_id AND a.del_flag = 1 AND ' +
        'a.zet_id = :id GROUP BY a.user_id ORDER BY a.user_id;')
    Params = <
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    DataSource = DMS.Dzet
    Left = 873
    Top = 304
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
  end
