  object asos: TZQuery
    Connection = DMS.lbd
    SQL.Strings = (
      
        'SELECT asos.id,nomer,s_diler.nom,concat(nomer,'#39' - '#39',s_diler.nom)' +
        ' as dilernom FROM asos,s_diler where asos.del_flag=1 and s_diler' +
        '.id=asos.diler_id and nomer is not null order by asos.id desc li' +
        'mit 10')
    Params = <>
    Left = 585
    Top = 288
  end
