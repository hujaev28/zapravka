  object tzakaz: TZQuery
    Connection = lbd
    SQL.Strings = (
      
        'select s.id,s.zakaz,s.kol,t.nom as s_tovar,user.username as s_us' +
        'er,s_izm.nom as s_izm_id,m.nom as stol from s_mobil m,asos a,use' +
        'r,s_tovar t, asos_slave s left JOIN s_izm on s_izm.id=s.izm_id w' +
        'here a.mobil=m.id and a.id=s.asos_id and t.id=s.tovar_id')
